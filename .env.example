APP_PORT=8000
APP_NAME=HMPay
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=hmpay
DB_USERNAME=hmpay
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@hmpay.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# ── Gateway clientes finais (Asaas) ──────────────────────────────────────────
ASAAS_API_KEY=
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=

# ── Gateway assinatura HMPay (AbacatePay) ────────────────────────────────────
ABACATEPAY_API_KEY=
ABACATEPAY_API_URL=https://api.abacatepay.com/v1
ABACATEPAY_WEBHOOK_SECRET=

# ── WhatsApp (Twilio) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Trial ─────────────────────────────────────────────────────────────────────
TRIAL_DAYS=14
SUBSCRIPTION_GRACE_DAYS=3
